# ── ContractSimplifier — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# Groq API key (backend only — never expose to frontend)
# Get a FREE key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional: Groq model to use (defaults to llama-3.3-70b-versatile if unset)
# Other free options: llama-3.1-8b-instant, mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# FastAPI server settings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Max input size in characters (default 50 000)
MAX_INPUT_CHARS=50000
