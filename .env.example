# ── ContractSimplifier — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# Anthropic Claude API key (backend only — never expose to frontend)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Claude model to use (defaults to claude-3-5-sonnet-20241022 if unset)
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# FastAPI server settings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Max input size in characters (default 50 000)
MAX_INPUT_CHARS=50000
